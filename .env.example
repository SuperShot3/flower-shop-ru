# EKB Flowers (Russia) — environment variables
# Copy to `.env.local` for local dev. Never copy Thailand `.env.local` from flower_shop.
#
# Quick checklist (.env.local):
#   [ ] POSTGRES_URL                  — Supabase pooler URL (Vercel integration or .env.local)
#   [ ] SUPABASE_URL                  — https://[ru-ref].supabase.co
#   [ ] SUPABASE_SERVICE_ROLE_KEY     — server-only (admin + storage uploads)
#   [ ] SUPABASE_ANON_KEY             — server-only (customer order token reads via RLS)
#   [ ] AUTH_SECRET                   — random 32+ chars
#   [ ] ADMIN_SEED_PASSWORD           — local only

# Canonical public site URL (order links, emails, OG tags)
NEXT_PUBLIC_APP_URL=https://www.ekb-flowers.ru

# PostgreSQL — Supabase (Vercel integration) or Docker locally
# Vercel Supabase sync sets POSTGRES_URL (pooled, port 6543).
# POSTGRES_URL=postgres://postgres.[ref]:[pass]@...pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
# lib/db/client.ts appends uselibpqcompat=true for remote URLs (pg 8.x SSL compat).
# Local dev: postgresql://flower:pass@localhost:5432/flower_ru
# POSTGRES_USER=flower
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=flower_ru

# Supabase JS client — Russia project only (Thailand ref blocked by validateRussiaEnv)
# SUPABASE_URL=https://[ru-ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_ANON_KEY=eyJ...   # Settings → API → anon public (server-only; do not NEXT_PUBLIC_* unless needed)

# Optional CDN override for catalog image URLs (defaults to SUPABASE_URL/storage/.../catalog/)
# CATALOG_CDN_URL=

# Yandex Metrica — analytics only (free browser counter)
# NEXT_PUBLIC_YANDEX_METRICA_ID=109816432

# YooKassa payments (later — not MVP)
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=

# Admin auth (new secret — not shared with Thailand)
# AUTH_SECRET=your-random-secret-at-least-32-chars
ADMIN_SEED_EMAIL=k.v.polovnikov@gmail.com
# ADMIN_SEED_PASSWORD=...

# Transactional email (later — Russian SMTP or provider)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ORDERS_FROM_EMAIL=orders@ekb-flowers.ru
# ORDERS_NOTIFY_EMAIL=k.v.polovnikov@gmail.com

# Cron endpoints (VPS crontab — later)
# CRON_SECRET=random-secret-for-cron-headers
