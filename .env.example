# EKB Flowers (Russia) — environment variables
# Copy to `.env.local` for local dev. Never copy Thailand `.env.local` from flower_shop.

# Canonical public site URL (order links, emails, OG tags)
NEXT_PUBLIC_APP_URL=https://www.ekb-flowers.ru

# PostgreSQL — Neon (Vercel MVP) or Docker locally
# Local dev: postgresql://flower:pass@localhost:5432/flower_ru
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/flower_ru?sslmode=require
# POSTGRES_USER=flower
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=flower_ru

# Catalog images — Vercel Blob on MVP (this project's store only, not Thailand)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Catalog images on VPS disk (after Timeweb migration; nginx serves /catalog/*)
# CATALOG_STORAGE_DIR=/var/www/catalog
# CATALOG_PUBLIC_BASE_URL=https://www.ekb-flowers.ru/catalog

# Yandex Metrica — analytics only (free browser counter)
# NEXT_PUBLIC_YANDEX_METRICA_ID=

# YooKassa payments (later — not MVP)
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=

# Admin auth (new secret — not shared with Thailand)
# AUTH_SECRET=your-random-secret-at-least-32-chars
ADMIN_SEED_EMAIL=k.v.polovnikov@yandex.ru
# ADMIN_SEED_PASSWORD=...

# Transactional email (later — Russian SMTP or provider)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ORDERS_FROM_EMAIL=orders@ekb-flowers.ru
# ORDERS_NOTIFY_EMAIL=k.v.polovnikov@gmail.com

# Cron endpoints (VPS crontab — later)
# CRON_SECRET=random-secret-for-cron-headers

# Catalog read source (default: postgres when DATABASE_URL is set)
# CATALOG_READ_SOURCE=postgres

# --- Export-only (local scripts, NEVER deploy to Vercel) ---
# Copy to `.env.export.local` (gitignored) for one-time Thailand migration:
# SUPABASE_EXPORT_URL=https://xxx.supabase.co
# SUPABASE_EXPORT_SERVICE_ROLE_KEY=eyJ...
# MIRROR_OUTPUT_DIR=./data/catalog
# MIRROR_PUBLIC_BASE_URL=https://www.ekb-flowers.ru/catalog
