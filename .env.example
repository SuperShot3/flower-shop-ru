# EKB Flowers (Russia) — environment variables
# Copy to `.env.local` for local dev. Never copy Thailand `.env.local` from flower_shop.
#
# Quick checklist (.env.local):
#   [ ] DATABASE_URL          — Russia Supabase (Vercel integration)
#   [ ] AUTH_SECRET           — random 32+ chars
#   [ ] ADMIN_SEED_PASSWORD   — local only
#   [ ] BLOB_READ_WRITE_TOKEN — Vercel Blob (catalog images + export upload)
#   [ ] .env.export.local     — one-time Thailand export (see bottom + .env.export.local.template)

# Canonical public site URL (order links, emails, OG tags)
NEXT_PUBLIC_APP_URL=https://www.ekb-flowers.ru

# PostgreSQL — Supabase (Vercel integration) or Docker locally
# Use the pooled connection string from Vercel/Supabase (port 6543).
# DATABASE_URL=postgres://postgres.[ref]:[pass]@...pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
# lib/db/client.ts appends uselibpqcompat=true for remote URLs (pg 8.x SSL compat).
# Local dev: postgresql://flower:pass@localhost:5432/flower_ru
# POSTGRES_USER=flower
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=flower_ru

# Catalog images — Vercel Blob on MVP (this project's store only, not Thailand)
# For local scripts (mirror-catalog): BLOB_READ_WRITE_TOKEN is required — starts with vercel_blob_rw_
# On Vercel deploy: Vercel may inject BLOB_STORE_ID + VERCEL_OIDC_TOKEN (OIDC). Do NOT rename
# BLOB_STORE_ID to a custom name — the SDK only reads BLOB_STORE_ID (you may duplicate as alias).
# Store must be PUBLIC for catalog <img> URLs. Private stores cannot be converted later.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# BLOB_UPLOAD_ACCESS=public
# BLOB_STORE_ID=store_...        # auto-set by Vercel when store is connected (keep this name)

# Catalog images on VPS disk (after Timeweb migration; nginx serves /catalog/*)
# CATALOG_STORAGE_DIR=/var/www/catalog
# CATALOG_PUBLIC_BASE_URL=https://www.ekb-flowers.ru/catalog

# Yandex Metrica — analytics only (free browser counter)
# NEXT_PUBLIC_YANDEX_METRICA_ID=

# YooKassa payments (later — not MVP)
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=

# Admin auth (new secret — not shared with Thailand)
# AUTH_SECRET=your-random-secret-at-least-32-chars
ADMIN_SEED_EMAIL=k.v.polovnikov@yandex.ru
# ADMIN_SEED_PASSWORD=...

# Transactional email (later — Russian SMTP or provider)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ORDERS_FROM_EMAIL=orders@ekb-flowers.ru
# ORDERS_NOTIFY_EMAIL=k.v.polovnikov@gmail.com

# Cron endpoints (VPS crontab — later)
# CRON_SECRET=random-secret-for-cron-headers

# --- Export-only (local scripts, NEVER deploy to Vercel) ---
# Copy template:  cp .env.export.local.template .env.export.local
# Full runbook: docs/export-catalog-from-thailand.md
#
# SUPABASE_EXPORT_URL=https://kwbffyojrdjlehdhpptf.supabase.co
# SUPABASE_EXPORT_SERVICE_ROLE_KEY=eyJ...
# MIRROR_OUTPUT_DIR=./data/catalog
# MIRROR_PUBLIC_BASE_URL=https://www.ekb-flowers.ru/catalog
# DATABASE_URL=<same as .env.local>
# BLOB_READ_WRITE_TOKEN=<optional — Russia Vercel Blob upload during mirror-catalog>
