# Russia storefront — environment variables (runtime)
# Copy to `.env.local` for local dev. Never copy Thailand `.env.local` from flower_shop.

# Canonical public site URL (order links, emails, OG tags)
# NEXT_PUBLIC_APP_URL=https://yourdomain.ru

# PostgreSQL — Docker on Timeweb VPS (same server as the app)
# Local dev: postgresql://flower:pass@localhost:5432/flower_ru
# Docker Compose: set POSTGRES_* below; app gets DATABASE_URL from compose
# DATABASE_URL=postgresql://flower:pass@localhost:5432/flower_ru
# POSTGRES_USER=flower
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=flower_ru

# Catalog images on VPS disk (nginx serves /catalog/*)
# CATALOG_STORAGE_DIR=/var/www/catalog
# Public URL prefix for image paths in DB (no CDN for MVP)
# CATALOG_PUBLIC_BASE_URL=https://yourdomain.ru/catalog

# Yandex Metrica — analytics only (free browser counter, not Yandex Cloud)
# NEXT_PUBLIC_YANDEX_METRICA_ID=

# YooKassa payments (Step 6)
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=

# Admin auth (new secret — not shared with Thailand)
# AUTH_SECRET=your-random-secret-at-least-32-chars
# ADMIN_SEED_EMAIL=admin@example.com
# ADMIN_SEED_PASSWORD=...

# Transactional email (Step 6 — Russian SMTP or provider)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ORDERS_FROM_EMAIL=orders@yourdomain.ru
# ORDERS_NOTIFY_EMAIL=

# Cron endpoints (VPS crontab)
# CRON_SECRET=random-secret-for-cron-headers

# Catalog read source (default: postgres when DATABASE_URL is set)
# CATALOG_READ_SOURCE=postgres

# --- Export-only (local scripts, NEVER deploy to VPS) ---
# Copy to `.env.export.local` (gitignored) for one-time Thailand migration:
# SUPABASE_EXPORT_URL=https://xxx.supabase.co
# SUPABASE_EXPORT_SERVICE_ROLE_KEY=eyJ...
# MIRROR_OUTPUT_DIR=./data/catalog
# MIRROR_PUBLIC_BASE_URL=https://yourdomain.ru/catalog
